{
  "release-type": "simple",
  "packages": {
    ".": {
      "component": "root",
      "include-component-in-tag": false,
      "extra-files": [
        {
          "type": "toml",
          "path": "Cargo.toml",
          "jsonpath": "$.workspace.package.version"
        },
        {
          "type": "toml",
          "path": "deluge-rpc-models/Cargo.toml",
          "jsonpath": "$.dependencies.deluge-rpc-rencode.version"
        },
        {
          "type": "toml",
          "path": "deluge-rpc-client/Cargo.toml",
          "jsonpath": "$.dependencies.deluge-rpc-rencode.version"
        },
        {
          "type": "toml",
          "path": "deluge-rpc-client/Cargo.toml",
          "jsonpath": "$.dependencies.deluge-rpc-models.version"
        }
      ]
    }
  }
}